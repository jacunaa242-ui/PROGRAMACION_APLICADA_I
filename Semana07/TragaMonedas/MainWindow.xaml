<Window x:Class="TragaMonedas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TragaMonedas"
        mc:Ignorable="d"
        Title="TragaMonedas" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78*"/>
            <RowDefinition Height="83*"/>
            <RowDefinition Height="75*"/>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="113*"/>
        </Grid.RowDefinitions>
        <Label x:Name="lbReloj" Content="00:00:00" HorizontalAlignment="Center"  VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Background="#FFFFDF05" Height="59" Width="154"/>
        <Grid Margin="0,78,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="297*"/>
                <ColumnDefinition Width="206*"/>
                <ColumnDefinition Width="297*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Margin="0,21,0,0">
                <Button x:Name="btnIniciarJuego" Content="Iniciar Juego" Height="40" FontWeight="Bold" FontSize="16" Click="btnIniciarJuego_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,83,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="154*"/>
                <ColumnDefinition Width="160*"/>
                <ColumnDefinition Width="169*"/>
                <ColumnDefinition Width="160*"/>
                <ColumnDefinition Width="157*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Margin="0,20,0,0">
                <TextBox x:Name="txtJugada1" TextWrapping="Wrap" Width="120" HorizontalAlignment="Center" TextAlignment="Center" FontSize="16" Height="32"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="0,20,0,0">
                <TextBox x:Name="txtJugada2" TextWrapping="Wrap" Width="120" TextAlignment="Center" FontSize="16" Height="32"/>
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="0,20,0,0">
                <TextBox x:Name="txtJugada3" TextWrapping="Wrap" Width="120" TextAlignment="Center" FontSize="16" Height="32"/>
            </StackPanel>
        </Grid>
        <Label x:Name="lbresultado" Content="Label" HorizontalAlignment="Center"  Grid.Row="3" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Width="123" Background="#FFB0FF0E" Visibility="Hidden"/>

    </Grid>
</Window>
