<Window x:Class="AdivinaEdad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdivinaEdad"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="57*"/>
            <RowDefinition Height="73*"/>
            <RowDefinition Height="43*"/>
            <RowDefinition Height="77*"/>
            <RowDefinition Height="58*"/>
            <RowDefinition Height="42*"/>
            <RowDefinition Height="84*"/>
        </Grid.RowDefinitions>
        <Label Content="Indicale al computador aun intervalo de edades" HorizontalAlignment="Center"  VerticalAlignment="Center" Height="25" Width="268" FontWeight="Bold" FontSize="14"/>
        <Grid Margin="0,57,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="186*"/>
                <ColumnDefinition Width="169*"/>
                <ColumnDefinition Width="90*"/>
                <ColumnDefinition Width="169*"/>
                <ColumnDefinition Width="186*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1">
                <TextBox x:Name="lbinferior" TextWrapping="Wrap" Width="168" Height="30" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBox x:Name="lbsuperior" TextWrapping="Wrap" Width="164" Height="30" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,73,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="63*"/>
                <ColumnDefinition Width="34*"/>
                <ColumnDefinition Width="63*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1">
                <Button x:Name="btnIntento" Content="Primer Intento" Height="37"/>
            </StackPanel>
        </Grid>
        <Label Content="La Computadora piensa que tu edad es:" HorizontalAlignment="Center"  Grid.Row="3" VerticalAlignment="Center" Height="28" Width="268" FontWeight="Bold" FontSize="14"/>
        <Grid Grid.Row="3" Margin="0,77,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="37*"/>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="37*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1">
                <TextBox x:Name="txtedadadivinada" TextWrapping="Wrap" Width="126" TextChanged="TextBox_TextChanged" FontSize="14" Height="31"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32*"/>
                <ColumnDefinition Width="33*"/>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="33*"/>
                <ColumnDefinition Width="32*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1">
                <Button x:Name="btncorrecto" Content="Correcto"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <Button x:Name="btnincorrecto" Content="Incorrecto"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
