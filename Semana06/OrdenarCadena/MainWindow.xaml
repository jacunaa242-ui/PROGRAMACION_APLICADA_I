<Window x:Class="OrdenarCadena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrdenarCadena"
        Height="550"
        Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">

        <!-- Filas -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Caja superior -->
        <TextBox x:Name="txtCadena" Grid.Row="0" Height="80" Margin="10" FontSize="18" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextChanged="txtCadena_TextChanged" Text="Liliana Angelina Leticia Amanda Patricia Roxana Luana Kiara Kimberly Synthia Cintia Cecilia Ana Lina Thalia Teresa Pierina"/>

        <!-- Botón Listar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="90,5">

            <Button x:Name="btnListar" Width="150" Height="40" FontWeight="Bold" FontSize="16" Content="&lt;&lt;Listar&gt;&gt;"/>
        </StackPanel>

        <!-- Parte central -->
        <Grid Grid.Row="2" Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Izquierda -->
            <StackPanel Grid.Column="0">

                <ListBox x:Name="lstNombres" Height="260" FontSize="16"/>

                <TextBox x:Name="txtCantidad1" Width="70" Margin="0,10,0,0" HorizontalAlignment="Left" IsReadOnly="True"/>

            </StackPanel>

            <!-- Centro -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                <Label Content="Letra" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

                <TextBox x:Name="txtLetra" Width="120" Height="35" FontSize="18" HorizontalContentAlignment="Center" Margin="0,10"/>

                <Button x:Name="btnPasar" Width="150" Height="40" FontWeight="Bold" FontSize="16" Content="&lt;&lt;Pasar&gt;&gt;"/>

            </StackPanel>

            <!-- Derecha -->
            <StackPanel Grid.Column="2">
                <ListBox x:Name="lstResultado" Height="260" FontSize="16"/>

                <TextBox x:Name="txtCantidad2" Width="70" Margin="0,20,0,0" HorizontalAlignment="Left" IsReadOnly="True" Height="25"/>
            </StackPanel>

        </Grid>

    </Grid>

</Window>
