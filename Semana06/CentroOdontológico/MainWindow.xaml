<Window x:Class="CentroOdontológico.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FechaCalendario" Height="600" Width="780" Background="#F4F7F6" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,30,0">

                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Paciente:" FontWeight="Medium" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox x:Name="txtPaciente" Grid.Column="1" Height="28" VerticalContentAlignment="Center" FontSize="13"/>
                </Grid>

                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Tratamiento:" FontWeight="Medium" VerticalAlignment="Center" FontSize="13"/>
                    <ComboBox x:Name="cmbTratamiento" Grid.Column="1" Height="28" VerticalContentAlignment="Center" FontSize="13">
                        <ComboBoxItem Content="Endodoncia"/>
                        <ComboBoxItem Content="Ortodoncia (Brackets)"/>
                        <ComboBoxItem Content="Blanqueamiento Dental"/>
                        <ComboBoxItem Content="Extracción Dental"/>
                        <ComboBoxItem Content="Curación con Resina"/>
                        <ComboBoxItem Content="Profilaxis (Limpieza)"/>
                        <ComboBoxItem Content="Implante Dental"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Pieza Dental:" FontWeight="Medium" VerticalAlignment="Center" FontSize="13"/>
                    <ComboBox x:Name="cmbPiezaDental" Grid.Column="1" Height="28" VerticalContentAlignment="Center" FontSize="13"/>
                </Grid>

            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Label Content="Fecha:" FontWeight="Medium" Margin="0,5,10,0" FontSize="13"/>
                <Calendar x:Name="calFecha" DisplayMode="Month" SelectionMode="SingleDate"/>
            </StackPanel>
        </Grid>

        <Button x:Name="btnCronogramar" Grid.Row="1" Content="Cronogramar" 
                HorizontalAlignment="Center" Padding="35,8" Margin="0,15"
                Click="btnCronogramar_Click" FontSize="14" FontWeight="SemiBold" 
                Cursor="Hand" Background="#E1E1E1"/>

        <ListBox x:Name="lstResultados" Grid.Row="2" Margin="0,10,0,0" 
                 Background="White" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D1D1D1" BorderThickness="0,0,0,1" Padding="10,6" Margin="0,2">
                        <TextBlock Text="{Binding}" FontFamily="Segoe UI" TextWrapping="Wrap" LineHeight="20"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
